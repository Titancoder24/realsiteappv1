# Supabase (app)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Supabase MCP (Cursor — get PAT at https://supabase.com/dashboard/account/tokens)
# Project ref = Project ID from Supabase Dashboard → Project Settings → General
SUPABASE_PROJECT_REF=your-project-ref
SUPABASE_ACCESS_TOKEN=your-personal-access-token

# World Labs (server-side only)
WORLD_LABS_API_KEY=your-world-labs-api-key
WORLD_LABS_API_BASE=https://api.worldlabs.ai

# SpAItial Echo — Immersive World generation (server-side only)
# Docs: https://docs.spaitial.ai/api/getting-started
SPAITIAL_API_KEY=spt_live_your-key-here

# OpenRouter (server-side only)
OPENROUTER_API_KEY=your-openrouter-api-key
OPENROUTER_PRIMARY_MODEL=google/gemini-3.5-flash
OPENROUTER_PLANNER_MODEL=google/gemini-3.5-flash
OPENROUTER_IMAGE_MODEL=google/gemini-3.1-flash-image-preview
OPENROUTER_VIDEO_MODEL=google/veo-3.1-lite

# ElevenLabs (server-side only)
ELEVENLABS_API_KEY=your-elevenlabs-api-key
ELEVENLABS_VOICE_ID=21m00Tcm4TlvDq8ikWAM

# Redis / BullMQ (optional — falls back to inline processing)
REDIS_URL=redis://localhost:6379

# LiveKit WebRTC (optional — family sessions)
LIVEKIT_API_KEY=
LIVEKIT_API_SECRET=
LIVEKIT_URL=wss://your-livekit-host

# Sentry (optional)
SENTRY_DSN=
NEXT_PUBLIC_SENTRY_DSN=

# Cron (optional — stuck World Labs job recovery)
CRON_SECRET=

# CDN (optional)
CDN_URL=

# App
NEXT_PUBLIC_APP_URL=http://localhost:3000
